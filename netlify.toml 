[build]
  publish = "."
  functions = "netlify/functions"

[functions]
  node_bundler = "esbuild"
  included_files = ["netlify/functions/**"]

[[headers]]
  for = "/*"
  [headers.values]
    Cache-Control = "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"

[[redirects]]
  from = "/api/create-story"
  to = "/.netlify/functions/create-story"
  status = 200

[[redirects]]
  from = "/api/generate-scene"
  to = "/.netlify/functions/generate-scene"
  status = 200

[[redirects]]
  from = "/api/export-project"
  to = "/.netlify/functions/export-project"
  status = 200

[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200
